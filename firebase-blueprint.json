{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "description": { "type": "string", "description": "Short description" },
        "longDescription": { "type": "string", "description": "Detailed description" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Project thumbnail" },
        "githubUrl": { "type": "string", "format": "uri", "description": "Source code link" },
        "liveUrl": { "type": "string", "format": "uri", "description": "Live demo link" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Technologies used" },
        "order": { "type": "integer", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "order"]
    },
    "Publication": {
      "title": "Publication",
      "description": "A research publication",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Paper title" },
        "authors": { "type": "string", "description": "List of authors" },
        "journal": { "type": "string", "description": "Journal or conference name" },
        "year": { "type": "integer", "description": "Year of publication" },
        "link": { "type": "string", "format": "uri", "description": "Link to paper" },
        "abstract": { "type": "string", "description": "Brief summary" },
        "order": { "type": "integer", "description": "Display order" }
      },
      "required": ["title", "authors", "year", "order"]
    },
    "Experience": {
      "title": "Experience",
      "description": "Work or research experience",
      "type": "object",
      "properties": {
        "company": { "type": "string", "description": "Organization name" },
        "role": { "type": "string", "description": "Job title" },
        "location": { "type": "string", "description": "City, Country" },
        "startDate": { "type": "string", "format": "date", "description": "Start date" },
        "endDate": { "type": "string", "format": "date", "description": "End date or 'Present'" },
        "description": { "type": "array", "items": { "type": "string" }, "description": "Key responsibilities" },
        "order": { "type": "integer", "description": "Display order" }
      },
      "required": ["company", "role", "startDate", "order"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/publications/{pubId}": {
      "schema": "Publication",
      "description": "Collection of research publications"
    },
    "/experience/{expId}": {
      "schema": "Experience",
      "description": "Collection of work experiences"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
